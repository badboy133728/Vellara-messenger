# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_REALTIME_V2=1

# Production: https://your-app.vercel.app (без слэша в конце)
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side Supabase connect timeout (ms). Default 25000.
SUPABASE_CONNECT_TIMEOUT_MS=25000

# Web Push (phone notifications when app is closed)
# Generate: node scripts/generate-vapid-keys.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# WebRTC STUN/TURN
# Полный JSON-массив (приоритетнее отдельных TURN_*):
WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:stun1.l.google.com:19302"}]
# Или отдельно TURN (нужен для звонков между разными сетями / мобильным интернетом):
# TURN_URL=turn:your-turn.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=
